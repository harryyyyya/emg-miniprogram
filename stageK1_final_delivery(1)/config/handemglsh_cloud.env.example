# Copy this file to config/local.env on Milk Duo S when connecting to the real cloud backend.
# Do not commit the copied local.env if it contains a real board token.

DUO_BACKEND_MODE=real
DUO_BACKEND_URL=https://api.handemglsh.cloud
DUO_REAL_BACKEND_GATE=ACCEPTED

DUO_HARDWARE_ID=DUOS-WIFI-001
DUO_BOARD_TOKEN=duos-secret
DUO_WIFI_HOST=0.0.0.0
DUO_WIFI_PORT=80

# Use upload mode when the mini program needs action recording data saved in MySQL/backend.
DUO_MODE=FULL_CHAIN_WITH_EMG_UPLOAD

# Keep these paths aligned with the actual files copied to the board.
DUO_MODEL_CONTRACT=/root/duo_fc_competition_v1/duo_s_full_chain/contracts/model_contract.json
DUO_CVIMODEL_PATH=/root/duo_fc_competition_v1/model/duo_fc_mlp_3session_v1_retry2_risk_accepted.cvimodel
DUO_PREPROCESS_PATH=/root/duo_fc_competition_v1/duo_s_full_chain/contracts/signal_pipeline.json
DUO_FEATURE_LIB=/root/duo_fc_competition_v1/build/libduo_emg_features.so

# Replace these after you verify the live board BLE and UART devices.
DUO_BLE_PLATFORM_MODULE=duo_s_full_chain.runtime.platform_api_template
DUO_UART_DEVICE=/dev/ttyS2
DUO_UART_SINK=/dev/ttyS2
