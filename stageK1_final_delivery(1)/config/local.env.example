# Copy to config/local.env on the board. Never return local.env in a ZIP.
# Keep mock unless a real backend has been separately accepted.
DUO_BACKEND_MODE=mock
DUO_BACKEND_URL=http://127.0.0.1:18080
DUO_BOARD_TOKEN=REPLACE_IN_UNPACKAGED_LOCAL_ENV_ONLY
DUO_HARDWARE_ID=DUO-S-COMPETITION
DUO_WIFI_HOST=127.0.0.1
DUO_WIFI_PORT=18080

# Default is exact-byte file capture. Do not guess ttyS1..3.
DUO_UART_SINK=file:/root/duo_fc_competition_v1/logs/uart_mock.bin
DUO_J3_UART_EVIDENCE=NOT_PROVEN

# Only after read-only pinout/device-tree/pinmux evidence and physical acceptance:
# DUO_UART_SINK=/dev/ttyS2
# DUO_J3_UART_EVIDENCE=LIVE_VERIFIED

# Only after real backend acceptance; credentials stay in this unreturned file:
DUO_REAL_BACKEND_GATE=NOT_PROVEN

