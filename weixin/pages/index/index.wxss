.home-page {
  padding-bottom: 120rpx;
}

/* 轮播 */
.banner-swiper {
  height: 360rpx;
  border-radius: 0 0 24rpx 24rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.45));
}

.banner-title {
  color: #FFF;
  font-size: 30rpx;
  font-weight: 600;
}

/* 设备卡片 */
.device-card {
  margin: 24rpx 30rpx;
  background: linear-gradient(135deg, #007AFF, #40A0FF);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.25);
}

.device-left {
  display: flex;
  align-items: center;
}

.device-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.device-dot.online {
  background: #34D058;
  box-shadow: 0 0 8rpx #34D058;
}

.device-dot.offline {
  background: #FF6B6B;
}

.device-name {
  color: #FFF;
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.device-status {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  display: block;
  margin-top: 4rpx;
}

.device-arrow {
  color: rgba(255, 255, 255, 0.6);
  font-size: 48rpx;
}

/* 功能金刚区 */
.feature-grid {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: #FFF;
  margin: 0 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.bg-blue { background: rgba(0, 122, 255, 0.1); }
.bg-green { background: rgba(52, 199, 89, 0.1); }
.bg-orange { background: rgba(255, 159, 10, 0.1); }
.bg-purple { background: rgba(88, 86, 214, 0.1); }

.feature-label {
  font-size: 24rpx;
  color: #333;
}

/* 段落标题 */
.section {
  margin: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 康复知识 */
.knowledge-list {
  background: #FFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.knowledge-item {
  display: flex;
  padding: 26rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.knowledge-item:last-child {
  border-bottom: none;
}

.knowledge-img {
  width: 172rpx;
  height: 126rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 22rpx;
  background: #EEE;
}

.knowledge-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
}

.knowledge-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.knowledge-tag {
  align-self: flex-start;
  margin-bottom: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 122, 255, 0.08);
  color: #007AFF;
  font-size: 20rpx;
}

.knowledge-desc {
  font-size: 23rpx;
  line-height: 1.55;
  color: #7a8799;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
