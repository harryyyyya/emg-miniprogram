<view class="home-page">
  <swiper class="banner-swiper" indicator-dots autoplay circular interval="4000" duration="600">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
      <view class="banner-overlay">
        <text class="banner-title">{{item.title}}</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="device-card" bindtap="goToBind">
    <view class="device-left">
      <view class="device-dot {{deviceOnline ? 'online' : 'offline'}}"></view>
      <view class="device-info">
        <text class="device-name">{{deviceName || '未绑定设备'}}</text>
        <text class="device-status">{{deviceStatusText}}</text>
      </view>
    </view>
    <text class="device-arrow">›</text>
  </view>

  <view class="feature-grid">
    <view class="feature-item" bindtap="goTo" data-url="/pages/control/control">
      <view class="feature-icon bg-blue">手</view>
      <text class="feature-label">假手控制</text>
    </view>
    <view class="feature-item" bindtap="goTo" data-url="/pages/control/control?tab=train">
      <view class="feature-icon bg-green">训</view>
      <text class="feature-label">数据训练</text>
    </view>
    <view class="feature-item" bindtap="goTo" data-url="/pages/control/control?tab=health">
      <view class="feature-icon bg-orange">康</view>
      <text class="feature-label">健康报告</text>
    </view>
    <view class="feature-item" bindtap="goTo" data-url="/pages/ai/ai">
      <view class="feature-icon bg-purple">AI</view>
      <text class="feature-label">AI 咨询</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">康复与训练</text>
      <text class="section-more">共 {{knowledgeList.length}} 篇</text>
    </view>
    <view class="knowledge-list">
      <view class="knowledge-item {{item.tone || ''}}" wx:for="{{knowledgeList}}" wx:key="id" bindtap="openArticle" data-id="{{item.id}}">
        <image class="knowledge-img" src="{{item.cover}}" mode="aspectFill" />
        <view class="knowledge-content">
          <text class="knowledge-title">{{item.title}}</text>
          <text class="knowledge-tag">{{item.tag}}</text>
          <text class="knowledge-desc">{{item.desc}}</text>
        </view>
        <text class="knowledge-arrow">›</text>
      </view>
    </view>
  </view>
</view>
