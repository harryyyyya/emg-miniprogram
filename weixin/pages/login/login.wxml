<view class="login-page">
  <view class="brand-area">
    <button class="brand-logo-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="brand-logo-wrap">
        <image class="brand-logo" src="{{avatarUrl || '/assets/icons/default_avatar.png'}}" mode="aspectFill" />
        <view class="edit-badge">头像</view>
      </view>
    </button>
    <text class="brand-title">肌电假手管理系统</text>
    <text class="brand-subtitle">智能 · 精准 · 康复</text>
  </view>

  <view class="login-card">
    <view class="tab-switch">
      <view class="tab-item {{loginMode === 'wechat' ? 'active' : ''}}" bindtap="switchMode" data-mode="wechat">微信登录</view>
      <view class="tab-item {{loginMode === 'phone' ? 'active' : ''}}" bindtap="switchMode" data-mode="phone">手机号登录</view>
    </view>

    <view class="patient-section">
      <text class="section-caption">患者信息</text>
      <view class="input-group">
        <text class="input-label">姓名</text>
        <input class="input-field" placeholder="请输入患者姓名" maxlength="32" bindinput="onPatientNameInput" value="{{patientName}}" />
      </view>
      <view class="input-group">
        <text class="input-label">截肢部位</text>
        <input class="input-field" placeholder="例如：左前臂、右手掌" maxlength="64" bindinput="onAmputationPartInput" value="{{amputationPart}}" />
      </view>
      <view class="input-group">
        <text class="input-label">患病时长（月）</text>
        <input class="input-field" type="number" placeholder="例如：6" maxlength="4" bindinput="onIllnessDurationInput" value="{{illnessDurationMonths}}" />
      </view>
    </view>

    <view wx:if="{{loginMode === 'wechat'}}" class="wechat-login">
      <text class="wechat-hint">登录后，患者资料会同步到网页端“报表管控”。</text>
      <button class="btn-primary btn-wechat" bindtap="onWechatLogin" loading="{{loggingIn}}" disabled="{{loggingIn}}">
        微信一键登录
      </button>
    </view>

    <view wx:if="{{loginMode === 'phone'}}" class="phone-login">
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" />
      </view>
      <view class="input-group code-group">
        <text class="input-label">验证码</text>
        <input class="input-field code-input" type="number" maxlength="6" placeholder="请输入验证码" bindinput="onCodeInput" value="{{code}}" />
        <button class="btn-code" disabled="{{codeCooldown > 0}}" bindtap="sendCode">
          {{codeCooldown > 0 ? codeCooldown + 's' : '获取验证码'}}
        </button>
      </view>
      <button class="btn-primary" bindtap="onPhoneLogin" loading="{{loggingIn}}" disabled="{{loggingIn}}">登录</button>
    </view>
  </view>

  <view class="agreement">
    <text>登录即表示同意</text>
    <text class="link">《用户协议》</text>
    <text>和</text>
    <text class="link">《隐私政策》</text>
  </view>
</view>
