<view class="profile-page">
  <view class="user-card">
    <view class="user-bg"></view>
    <view class="user-info-wrapper">
      <view class="avatar-wrap" bindtap="changeAvatar">
        <image class="user-avatar" src="{{avatarUrl || '/assets/icons/default_avatar.png'}}" mode="aspectFill" />
        <view class="avatar-edit">改</view>
      </view>
      <view class="user-detail">
        <view class="user-name-row">
          <text class="user-name">{{userName || '未登录'}}</text>
          <text class="user-name-edit" bindtap="editUserName">修改</text>
        </view>
        <text class="user-phone">{{userPhone || '点击登录'}}</text>
      </view>
    </view>
  </view>

  <view class="section-card" wx:if="{{boundDevice}}">
    <view class="card-title">绑定设备</view>
    <view class="device-info-row">
      <text class="info-label">设备名称</text>
      <text class="info-value">{{boundDevice.name || boundDevice.hardware_id}}</text>
    </view>
    <view class="device-info-row">
      <text class="info-label">通信方式</text>
      <text class="info-value">{{boundDevice.transport === 'wifi' ? 'Wi-Fi' : 'BLE'}}</text>
    </view>
    <view class="device-info-row">
      <text class="info-label">绑定时间</text>
      <text class="info-value">{{bindTimeStr}}</text>
    </view>
    <view class="device-info-row">
      <text class="info-label">连接状态</text>
      <text class="info-value {{isConnected ? 'text-green' : 'text-red'}}">{{connectionText}}</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goTo" data-url="/pages/bind/bind">
      <text class="menu-icon">设</text>
      <text class="menu-label">设备管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTo" data-url="/pages/control/control?tab=health">
      <text class="menu-icon">报</text>
      <text class="menu-label">健康报告</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTo" data-url="/pages/control/control?tab=train">
      <text class="menu-icon">训</text>
      <text class="menu-label">训练记录</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goTo" data-url="/pages/devguide/devguide">
      <text class="menu-icon">指</text>
      <text class="menu-label">开发与调试指南</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">设</text>
      <text class="menu-label">系统设置</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">帮</text>
      <text class="menu-label">帮助与反馈</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="logout-section" wx:if="{{userName}}">
    <button class="btn-logout" bindtap="logout">退出登录</button>
  </view>

  <view class="version-info">
    <text>版本 v1.0.0</text>
  </view>
</view>
