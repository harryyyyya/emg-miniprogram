.profile-page {
  padding-bottom: 120rpx;
}

/* 用户卡片 */
.user-card {
  position: relative;
  margin-bottom: 30rpx;
}

.user-bg {
  height: 280rpx;
  background: linear-gradient(135deg, #007AFF, #40A0FF, #7BC8FF);
  border-radius: 0 0 40rpx 40rpx;
}

.user-info-wrapper {
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  margin-top: -80rpx;
  position: relative;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #FFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #007AFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: 3rpx solid #FFF;
}

.user-detail {
  margin-left: 24rpx;
  padding-top: 40rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.user-name-edit {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
  font-size: 22rpx;
}

.user-phone {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

/* 设备信息卡片 */
.section-card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.device-info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.device-info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.text-green { color: #34C759; }
.text-red { color: #FF3B30; }

/* 菜单 */
.menu-card {
  background: #FFF;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* 退出按钮 */
.logout-section {
  padding: 40rpx 30rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background: #FFF;
  color: #FF3B30;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF3B30;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-logout::after { border: none; }

.version-info {
  text-align: center;
  font-size: 22rpx;
  color: #CCC;
  padding: 20rpx;
}
