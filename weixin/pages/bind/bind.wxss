.bind-page {
  min-height: 100vh;
  padding: 40rpx 28rpx 80rpx;
  background:
    radial-gradient(circle at top left, rgba(0, 122, 255, 0.12), transparent 36%),
    linear-gradient(180deg, #f5f8ff 0%, #ffffff 48%, #eef6f1 100%);
}

.mode-switch {
  display: flex;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.mode-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(11, 89, 214, 0.08);
  box-shadow: 0 12rpx 30rpx rgba(25, 76, 146, 0.08);
}

.mode-item.active {
  background: linear-gradient(135deg, #0b59d6, #1693ff);
}

.mode-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #20304a;
}

.mode-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7d99;
}

.mode-item.active .mode-title,
.mode-item.active .mode-desc {
  color: #ffffff;
}

.scan-section,
.search-section,
.success-section,
.fail-section {
  margin-top: 24rpx;
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(19, 64, 128, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-frame {
  width: 320rpx;
  height: 320rpx;
  border-radius: 28rpx;
  border: 4rpx dashed rgba(22, 147, 255, 0.35);
  background: linear-gradient(135deg, rgba(11, 89, 214, 0.08), rgba(22, 147, 255, 0.02));
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-emoji {
  font-size: 120rpx;
}

.scan-hint,
.search-sub,
.result-hint {
  margin: 28rpx 0 40rpx;
  text-align: center;
  line-height: 1.7;
  font-size: 26rpx;
  color: #627187;
}

.btn-primary,
.btn-secondary {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #0b59d6, #1693ff);
  box-shadow: 0 14rpx 28rpx rgba(11, 89, 214, 0.24);
  border: none;
}

.btn-secondary {
  margin-top: 20rpx;
  color: #0b59d6;
  background: transparent;
  border: 2rpx solid rgba(11, 89, 214, 0.24);
}

.btn-primary::after,
.btn-secondary::after {
  border: none;
}

.wifi-section {
  margin-top: 24rpx;
}

.form-card {
  padding: 34rpx 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 40rpx rgba(19, 64, 128, 0.08);
}

.form-header {
  margin-bottom: 28rpx;
}

.form-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #20304a;
}

.form-subtitle {
  display: block;
  margin-top: 10rpx;
  line-height: 1.7;
  font-size: 24rpx;
  color: #6b7d99;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #40526d;
}

.form-input {
  height: 86rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f5f8ff;
  border: 2rpx solid rgba(11, 89, 214, 0.08);
  font-size: 28rpx;
  color: #20304a;
}

.loading-ring {
  width: 120rpx;
  height: 120rpx;
  border: 8rpx solid rgba(22, 147, 255, 0.14);
  border-top-color: #0b59d6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.search-text,
.result-title {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #20304a;
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
}

.result-icon.success {
  background: rgba(53, 174, 93, 0.14);
  color: #1f8b4c;
}

.result-icon.fail {
  background: rgba(255, 91, 91, 0.14);
  color: #d83a3a;
}

.result-device {
  margin-top: 16rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(11, 89, 214, 0.08);
  font-size: 26rpx;
  color: #0b59d6;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 34rpx 32rpx;
  border-radius: 32rpx;
  color: #ffffff;
  background:
    radial-gradient(circle at 85% 10%, rgba(255, 255, 255, 0.28), transparent 28%),
    linear-gradient(135deg, #082b62 0%, #0b59d6 56%, #19a56b 100%);
  box-shadow: 0 18rpx 44rpx rgba(11, 89, 214, 0.22);
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.76);
}

.hero-title {
  display: block;
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  line-height: 1.7;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.84);
}

.primary-card {
  border: 2rpx solid rgba(11, 89, 214, 0.1);
}

.device-summary {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(11, 89, 214, 0.08), rgba(31, 157, 85, 0.08));
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 10rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: #6b7d99;
}

.summary-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 700;
  color: #20304a;
  word-break: break-all;
}

.btn-link {
  margin-top: 20rpx;
  color: #5d6f8a;
  background: transparent;
  font-size: 26rpx;
}

.btn-link::after {
  border: none;
}

.compact {
  height: 78rpx;
  font-size: 28rpx;
}

.advanced-panel {
  margin-top: 26rpx;
  padding-top: 26rpx;
  border-top: 2rpx dashed rgba(11, 89, 214, 0.16);
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.tips-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: rgba(6, 24, 38, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(6, 24, 38, 0.12);
}

.tips-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
}

.tips-line {
  display: block;
  margin-top: 8rpx;
  line-height: 1.6;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.76);
}
