/* pages/slides/slides.wxss */

.slides-page {
  height: 100vh;
  background: #0a0f1e;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ── 进度点 ── */
.dots {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0 10rpx;
  flex-shrink: 0;
}
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  transition: all 0.3s;
}
.dot--active {
  width: 28rpx;
  border-radius: 5rpx;
  background: #4f8ef7;
}

/* ── Swiper ── */
.swiper {
  flex: 1;
  width: 100%;
}

/* ── 通用 slide ── */
.slide {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 48rpx 20rpx;
  box-sizing: border-box;
  position: relative;
}
.slide-num {
  position: absolute;
  bottom: 16rpx;
  right: 40rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
}

/* ── 封面 ── */
.slide--cover {
  background: linear-gradient(145deg, #0d1b3e 0%, #102050 60%, #0a1a3a 100%);
}
.cover-badge {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  background: rgba(79,142,247,0.2);
  border: 1px solid rgba(79,142,247,0.5);
  color: #4f8ef7;
  font-size: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  letter-spacing: 2px;
}
.cover-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.cover-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  line-height: 1.3;
  margin-bottom: 16rpx;
}
.cover-sub {
  font-size: 30rpx;
  color: rgba(255,255,255,0.55);
  margin-bottom: 48rpx;
}
.cover-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}
.tag {
  background: rgba(79,142,247,0.15);
  border: 1px solid rgba(79,142,247,0.4);
  color: #7eb8ff;
  font-size: 24rpx;
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
}

/* ── 功能页 ── */
.slide--feature {
  background: linear-gradient(145deg, #0d1b3e 0%, #0e1e44 100%);
  align-items: flex-start;
}
.slide-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  align-self: center;
}
.slide-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  align-self: center;
}
.slide-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 32rpx;
  align-self: center;
  text-align: center;
}
.item-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 10rpx;
}
.item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: rgba(79,142,247,0.08);
  border-left: 4rpx solid #4f8ef7;
  border-radius: 0 16rpx 16rpx 0;
  padding: 20rpx 24rpx;
}
.item-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4f8ef7;
  flex-shrink: 0;
  margin-top: 8rpx;
}
.item-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.6;
}

/* ── 架构页 ── */
.slide--arch {
  background: linear-gradient(145deg, #0d1b3e 0%, #0e1e44 100%);
  align-items: flex-start;
}
.arch-label {
  font-size: 22rpx;
  color: #4f8ef7;
  letter-spacing: 2px;
  font-weight: 600;
  margin: 16rpx 0 12rpx;
  align-self: flex-start;
}
.arch-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  width: 100%;
}
.arch-card {
  background: rgba(79,142,247,0.1);
  border: 1px solid rgba(79,142,247,0.25);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}
.arch-card-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #7eb8ff;
  margin-bottom: 4rpx;
}
.arch-card-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  line-height: 1.4;
}
.util-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.util-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
}
.util-icon { font-size: 28rpx; }
.util-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  font-family: monospace;
}

/* ── 表格页 ── */
.slide--table {
  background: linear-gradient(145deg, #0d1b3e 0%, #0e1e44 100%);
  align-items: flex-start;
  justify-content: flex-start;
  padding-top: 40rpx;
}
.table {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 16rpx;
  border: 1px solid rgba(79,142,247,0.2);
}
.table-head {
  display: flex;
  background: rgba(79,142,247,0.2);
  padding: 16rpx 12rpx;
}
.th {
  font-size: 22rpx;
  color: #7eb8ff;
  font-weight: 600;
}
.table-row {
  display: flex;
  padding: 16rpx 12rpx;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.row--even {
  background: rgba(255,255,255,0.03);
}
.td {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
}

/* Mock策略 */
.th--scene, .td--scene { flex: 2; padding-right: 8rpx; }
.th--strategy, .td--strategy { flex: 3; }

/* 存储Key */
.th--key, .td--key { flex: 3; font-family: monospace; color: #7eb8ff; }
.th--type, .td--type { flex: 2; color: #f0c040; }
.th--desc, .td--desc { flex: 4; }

/* ── 结尾 ── */
.slide--end {
  background: linear-gradient(145deg, #0d1b3e 0%, #102050 60%, #0a1a3a 100%);
}
.end-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.end-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}
.end-sub {
  font-size: 30rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 48rpx;
}
.end-tags {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 80%;
}
.end-tag {
  background: rgba(79,142,247,0.12);
  border: 1px solid rgba(79,142,247,0.35);
  color: #7eb8ff;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  text-align: center;
}

/* ── 底部导航栏 ── */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx 36rpx;
  background: rgba(0,0,0,0.4);
  flex-shrink: 0;
}
.nav-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: rgba(79,142,247,0.15);
  border: 1px solid rgba(79,142,247,0.35);
  border-radius: 40rpx;
  transition: all 0.2s;
}
.nav-btn--disabled {
  opacity: 0.3;
  pointer-events: none;
}
.nav-arrow {
  font-size: 40rpx;
  color: #7eb8ff;
  line-height: 1;
}
.nav-label {
  font-size: 24rpx;
  color: #7eb8ff;
}
.nav-progress {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.nav-cur {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}
.nav-sep {
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
}
.nav-total {
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
}
