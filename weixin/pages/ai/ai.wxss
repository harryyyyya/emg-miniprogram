.ai-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F4F7FB;
}

/* 设备绑定信息条 */
.device-bar {
  display: flex;
  align-items: center;
  background: #FFF;
  padding: 16rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.device-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.device-dot.online {
  background: #34D058;
  box-shadow: 0 0 6rpx #34D058;
}

.device-bar-text {
  font-size: 24rpx;
  color: #666;
}

/* 聊天列表 */
.chat-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
  /* 关键修复 */
  width: 100%;
  box-sizing: border-box;
}
.chat-welcome {
  width: 100%;
  box-sizing: border-box; /* 关键：宽度包含padding，不会被压缩 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}

.welcome-emoji {
  min-width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #007AFF, #40A0FF);
  color: #FFF;
  font-size: 42rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.quick-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.quick-item {
  background: #FFF;
  border: 2rpx solid #007AFF;
  color: #007AFF;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

/* 消息行 */
.msg-row {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.msg-right {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E8F0FE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.msg-right .msg-avatar {
  background: #007AFF;
}

.msg-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  margin: 0 16rpx;
}

.bubble-ai {
  background: #FFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bubble-user {
  background: linear-gradient(135deg, #007AFF, #40A0FF);
}

.bubble-user .msg-text {
  color: #FFF;
}

.msg-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.msg-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8A94A6;
}

/* 打字指示器 */
.typing-indicator {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.dot-typing {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #CCC;
  animation: dotPulse 1.4s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 底部输入 */
.input-bar {
  display: flex;
  padding: 16rpx 24rpx;
  background: #FFF;
  border-top: 1rpx solid #F0F0F0;
  align-items: center;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #F4F7FB;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.btn-send {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #007AFF, #40A0FF);
  color: #FFF;
  font-size: 28rpx;
  border-radius: 36rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-send::after { border: none; }

.btn-send[disabled] {
  background: #CCC;
}
