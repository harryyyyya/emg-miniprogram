.article-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 80rpx;
  background:
    radial-gradient(circle at top right, rgba(0, 122, 255, 0.12), transparent 34%),
    linear-gradient(180deg, #f5f8ff 0%, #ffffff 54%, #f2f8f1 100%);
}

.article-page.warm {
  background:
    radial-gradient(circle at 82% 8%, rgba(255, 176, 96, 0.24), transparent 34%),
    radial-gradient(circle at 10% 26%, rgba(255, 226, 190, 0.48), transparent 30%),
    linear-gradient(180deg, #fff8ef 0%, #fffdf8 52%, #fff1e5 100%);
}

.article-hero,
.article-section {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 34rpx rgba(17, 56, 110, 0.08);
}

.article-hero {
  padding: 34rpx 30rpx;
  background:
    radial-gradient(circle at 82% 12%, rgba(255,255,255,0.28), transparent 28%),
    linear-gradient(135deg, #082b62, #0b59d6 62%, #19a56b);
  color: #ffffff;
}

.article-hero.warm {
  background:
    radial-gradient(circle at 86% 10%, rgba(255, 255, 255, 0.32), transparent 28%),
    linear-gradient(135deg, #a84f20, #e07b39 58%, #f6b25f);
}

.article-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.article-title {
  display: block;
  margin-top: 22rpx;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 800;
}

.article-summary {
  display: block;
  margin-top: 18rpx;
  line-height: 1.7;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.84);
}

.article-section {
  margin-top: 24rpx;
  padding: 28rpx;
}

.tips-section {
  border: 1rpx solid rgba(31, 157, 85, 0.14);
}

.section-heading {
  display: block;
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #20304a;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f7fafc;
}

.advice-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #0b59d6;
  flex-shrink: 0;
}

.advice-dot.accent {
  background: #1f9d55;
}

.article-page.warm .advice-dot {
  background: #e07b39;
}

.article-page.warm .advice-dot.accent {
  background: #d05f28;
}

.advice-text {
  flex: 1;
  line-height: 1.65;
  font-size: 25rpx;
  color: #50627e;
}
